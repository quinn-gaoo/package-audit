{
  "name": "dep-guard",
  "version": "1.0.0",
  "description": "Dependency audit tool with MCP support",
  "main": "build/index.js",
  "types": "build/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc && chmod +x build/cli.js",
    "dev": "tsx src/index.ts",
    "cli:dev": "tsx src/cli.ts",
    "cli:test": "tsx src/cli.ts --help",
    "test": "tsx src/test.ts",
    "mcp:dev": "tsx src/mcp/index.tsx",
    "inspector": "npx @modelcontextprotocol/inspector",
    "cli:install": "pnpm link --global"
  },
  "bin": {
    "github-audit": "./build/cli.js"
  },
  "files": [
    "build"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.7.1",
  "dependencies": {
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "execa": "^9.6.1",
    "node-async-exec": "^1.2.0",
    "ora": "^9.4.0",
    "tmp": "^0.2.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/inspector": "^0.21.2",
    "@types/node": "^25.6.2",
    "@types/tmp": "^0.2.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
